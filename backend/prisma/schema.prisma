generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPRESA_FUNC
}

enum TipoItem {
  PROTEINA
  COMPLEMENTO
}

enum FormaPagamento {
  PIX
  CREDITO
  DEBITO
  DINHEIRO
}

enum StatusPagamento {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

enum TipoPratoSelfService {
  SELF_SERVICE_18
  SELF_SERVICE_15
}

enum StatusReservaSelfService {
  AGUARDANDO_PAGAMENTO
  PAGO
  RETIRADO
  CANCELADO
}

enum StatusPedidoEmpresa {
  ENVIADO
  AUTORIZADO
  IMPRESSO
}

enum TamanhoMarmita {
  GRANDE
  PEQUENA
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(EMPRESA_FUNC)
  empresaId Int?
  empresa   Empresa? @relation(fields: [empresaId], references: [id])
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Empresa {
  id                 Int                  @id @default(autoincrement())
  nome               String
  sigla              String?              @unique
  senha              String?
  totalPedidos       Int
  valorMarmita       Float                @default(0)
  funcionarios       Usuario[]
  funcionariosSalvos EmpresaFuncionario[]
  pedidos            PedidoEmpresa[]
  ativo              Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model EmpresaFuncionario {
  id        Int      @id @default(autoincrement())
  empresaId Int
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, nome])
}

model ItemCardapio {
  id        Int      @id @default(autoincrement())
  nome      String
  tipo      TipoItem
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PedidoAvulso {
  id              Int             @id @default(autoincrement())
  nomeCliente     String
  telefone        String
  endereco        String
  tamanhoMarmita  TamanhoMarmita?
  itens           Json
  quantidade      Int             @default(1)
  valorUnitario   Float           @default(0)
  valorTotal      Float           @default(0)
  valorPago       Float?
  observacao       String?
  formaPagamento  FormaPagamento
  statusPagamento StatusPagamento @default(PENDENTE)
  mercadoPagoId   String?
  mercadoPagoPreferenceId String?
  referenciaExterna String?       @unique
  pagoEm          DateTime?
  motoqueiro      String?
  valorTroco      Float?
  impresso        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model PedidoEmpresa {
  id        Int                 @id @default(autoincrement())
  empresaId Int
  empresa   Empresa             @relation(fields: [empresaId], references: [id])
  lotes     LotePedido[]
  observacao String?
  status    StatusPedidoEmpresa @default(ENVIADO)
  impresso  Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model ReservaSelfService {
  id             Int                      @id @default(autoincrement())
  nomeCliente    String
  whatsapp       String
  tipoPrato      TipoPratoSelfService
  valorPrato     Float
  taxaServico    Float                    @default(0.2)
  valorTotal     Float
  status         StatusReservaSelfService @default(AGUARDANDO_PAGAMENTO)
  mercadoPagoId  String?
  referenciaExterna String?               @unique
  valorPago      Float?
  pagoEm         DateTime?
  codigoRetirada String?                  @unique
  retiradoEm     DateTime?
  canceladoEm    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
}

model LotePedido {
  id              Int           @id @default(autoincrement())
  pedidoEmpresaId Int
  pedidoEmpresa   PedidoEmpresa @relation(fields: [pedidoEmpresaId], references: [id], onDelete: Cascade)
  itens           Json
  quantidade      Int
  endereco        String
  nomes           Json?
  createdAt       DateTime      @default(now())
}

model Banner {
  id        Int      @id @default(autoincrement())
  titulo    String?
  texto     String?
  imagemUrl String
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarmitaCard {
  id        Int            @id @default(autoincrement())
  tamanho   TamanhoMarmita @unique
  titulo    String
  preco     Float
  imagemUrl String?
  ativo     Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ControleDiario {
  id        Int      @id @default(autoincrement())
  data      String   @unique
  secoes    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
